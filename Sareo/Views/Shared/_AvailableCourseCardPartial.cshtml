@model Sareoo.ViewModels.AvailableCourseViewModel
@using Sareoo.Helpers

@{
    // إعداد رابط الواتساب مدمج باسم الكورس
    string whatsappNumber = "201150459759";
    string whatsappMessage = Uri.EscapeDataString($"السلام عليكم، أريد الاشتراك في دورة: {Model.Title}");
    string whatsappLink = $"https://wa.me/{whatsappNumber}?text={whatsappMessage}";
}

<div class="course-card h-100 shadow-sm">
    <div class="img">
        <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl) ? $"https://placehold.co/600x400/1b263b/e0e1dd?text={Model.Title}" : Model.CoverImageUrl)" class="card-img-top" alt="@Model.Title">
    </div>
    <div class="card-body p-4 d-flex flex-column">
        <h3 class="mb-0">@Model.Title</h3>
        <p class="text-blue fs-5 mb-2">@Model.TeacherName</p>

        <div class="icons d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
            <div class="icon1">
                <i class="fas fa-clock"></i>
                <span class="d-inline-block me-1 text-white">@ArabicNumberHelper.ToArabicNumerals(Model.TotalHours) ساعة</span>
            </div>
            <div class="icon2">
                <i class="fas fa-book ms-1"></i>
                <span class="d-inline-block text-white">@ArabicNumberHelper.ToArabicNumerals(Model.LessonsCount) درس</span>
            </div>
        </div>

        <div class="mt-3 d-flex flex-column gap-2">
            @if (Model.IsSubscribed)
            {
                <a asp-controller="CoursePlayer" asp-action="Index" asp-route-courseId="@Model.Id" class="btn see-btn w-100 m-0">عرض الدورة</a>
            }
            else
            {
                <!-- زرار الواتساب -->
                <a href="@whatsappLink" target="_blank" class="btn w-100 fw-bold d-flex justify-content-center align-items-center" style="background-color: #25D366; color: white; border-radius: 50px; padding: 10px; border: none; transition: all 0.3s;" onmouseover="this.style.backgroundColor='#128C7E'" onmouseout="this.style.backgroundColor='#25D366'">
                    <i class="fab fa-whatsapp fa-lg me-2"></i> اشترك الآن
                </a>
                
                <!-- زرار التفاصيل (لرؤية الفيديوهات المجانية) -->
                <a asp-controller="Home" asp-action="CourseDetails" asp-route-id="@Model.Id" class="btn see-btn w-100 m-0">
                    <i class="fas fa-info-circle me-1"></i> التفاصيل والمعاينة
                </a>
            }
        </div>
    </div>
</div>